{
  "name": "ceditor",
  "version": "1.0.0",
  "description": "Web-based editor for managing game asset JSON files",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "install:deps": "npm ci"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.21.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/node": "20.19.24",
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "8.2.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  }
}
